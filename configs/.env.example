# Yufa-MT environment configuration.
# Copy to ".env" at the repo root and fill in values. The app loads ".env"
# automatically via godotenv. Anything set in the real shell environment
# takes precedence over ".env".

# --- Admin ---
# If unset, a random password is generated on startup and written to
# data/pwd.txt. For production, set this explicitly.
ADMIN_PASSWORD=

# --- Discord bot ---
# Bot token from the Discord developer portal.
DISCORD_BOT_TOKEN=
# Comma-separated channel IDs the bot should listen in.
DISCORD_CHANNEL_IDS=

# --- Gemini (Google Generative AI) ---
# API key used to parse free-text trade messages into structured items.
GEMINI_API_KEY=

# --- Chat capture (optional) ---
# Network device to sniff for in-game chat packets (e.g. "eth0"). Leave
# unset to disable chat capture.
CHAT_CAPTURE_DEVICE=
# TCP port of the game server to filter packets on.
CHAT_CAPTURE_PORT=
